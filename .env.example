APP_NAME=ReportFlow AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

MYSQL_DATABASE=reportflow
MYSQL_USER=reportflow
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

DATABASE_URL=mysql+pymysql://reportflow:change_me@mysql:3306/reportflow?charset=utf8mb4

JWT_SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=1440

STORAGE_ROOT=./storage
#OCR_PROVIDER=mock
OCR_PROVIDER=paddle
#AI_PROVIDER=mock
AI_PROVIDER=deepseek
AI_API_KEY=sk-placeholder
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_SECONDS=60
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:8080","http://127.0.0.1:8080"]

VITE_API_BASE_URL=http://localhost:8000/api/v1
