APP_NAME=ReportFlow AI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

MYSQL_DATABASE=reportflow
MYSQL_USER=reportflow
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_password
MYSQL_HOST=mysql
MYSQL_PORT=3306

DATABASE_URL=mysql+pymysql://reportflow:change_me@mysql:3306/reportflow?charset=utf8mb4

JWT_SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=1440

STORAGE_ROOT=./storage
OCR_PROVIDER=mock
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VISION_MODEL=qwen3-vl-plus
QWEN_TIMEOUT_SECONDS=60
GITHUB_API_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TIMEOUT_SECONDS=30
AI_PROVIDER=mock
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TIMEOUT_SECONDS=60
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174","http://localhost:8080","http://127.0.0.1:8080"]

VITE_API_BASE_URL=http://localhost:8000/api/v1
